# DeepSeek API 默认配置（前端可覆盖）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-flash

# 服务配置
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# JWT 签名密钥（生产环境务必更换为随机字符串，例如：openssl rand -hex 32）
JWT_SECRET=change-me-to-a-random-secret
# CORS 允许的域名（逗号分隔，默认 * 允许所有，生产环境请限定为实际域名）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# LLM 调用超时（秒），非流式默认 60s，流式默认 120s
LLM_TIMEOUT=60.0
LLM_STREAM_TIMEOUT=120.0

# whisper.cpp GPU 加速层数（需编译 GPU 版 pywhispercpp）
# 0=仅CPU，设为 32 或更高以启用 GPU（NVIDIA/Apple/其他）
WHISPER_N_GPU_LAYERS=0
